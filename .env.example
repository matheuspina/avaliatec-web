# Environment Variables Configuration
# Copie este arquivo para .env.local e preencha com suas credenciais

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Preencha todas as variáveis necessárias abaixo
# 3. Para WhatsApp (Evolution API):
#    - Configure sua instância Evolution API
#    - Configure o webhook URL: {NEXT_PUBLIC_APP_URL}/api/webhooks/evolution
#    - A Evolution API deve estar configurada para enviar eventos para este webhook
# 4. Reinicie a aplicação após alterar as variáveis

# Supabase Configuration
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api

# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon key) - segura para usar no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Login Microsoft (Azure) via Supabase: se o app no Entra ID for "Somente esta organização"
# (single-tenant), o Supabase NÃO pode usar /common — configure no Dashboard do Supabase:
# Authentication → Providers → Azure → "Azure Tenant URL":
#   https://login.microsoftonline.com/<SEU_DIRECTORY-TENANT-ID>
# (ID em Entra ID → Visão geral → ID do locatário). Alternativa: tornar o app multi-tenant no Azure.
# Ver: https://supabase.com/docs/guides/auth/social-login/auth-azure#configure-a-tenant-url-optional

# Chave de serviço (service role) - NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=

# Database URL (opcional, para migrações e MCP)
DATABASE_URL=

# Mapbox (autocompletar de endereços) — crie um token em https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Azure (Microsoft Graph / Outlook no app — não substitui o Tenant URL do provider no Supabase)
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_TENANT_ID=

# Evolution API Configuration (WhatsApp Integration)
# Configure com as credenciais da sua instância Evolution API
# Obtenha em: https://doc.evolution-api.com/

# URL base da sua instância Evolution API
# Exemplo: https://api.evolution-api.com ou http://localhost:8080
# Esta URL será usada para todas as chamadas à API (criar instâncias, enviar mensagens, etc.)
EVOLUTION_API_BASE_URL=https://api.evolution-api.com

# Chave de API da Evolution API
# Chave de autenticação para acessar a Evolution API
# Obtida no painel de administração da sua instância Evolution API
# Esta chave é enviada no header Authorization: Bearer {EVOLUTION_API_KEY}
EVOLUTION_API_KEY=

# Webhook Configuration
# URL base da sua aplicação (onde a Evolution API enviará os webhooks)
# Exemplo: https://seu-dominio.com ou http://localhost:3000
# A Evolution API enviará eventos para: {NEXT_PUBLIC_APP_URL}/api/webhooks/evolution
# Também usada em produção para redirects do /auth/callback (login Microsoft) quando há proxy.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook Security (opcional)
# Chave secreta para validar webhooks da Evolution API
# Gere uma string aleatória segura (ex: openssl rand -hex 32)
# Usada para verificar se os webhooks realmente vêm da Evolution API
# Configure a mesma chave na Evolution API para validação de assinatura
WEBHOOK_SECRET=

# =============================================================================
# GOOGLE DRIVE INTEGRATION
# =============================================================================
# Para integração com Google Drive via Service Account:
#
# 1. Acesse https://console.cloud.google.com/
# 2. Crie/use um projeto e habilite a Google Drive API
# 3. Crie uma Service Account e gere uma chave JSON
# 4. Copie TODO o conteúdo do JSON e serialize em uma única linha (substitua \n por \\n na private_key)
#    ou use: node -e "console.log(JSON.stringify(require('./sua-chave.json')))"
# 5. Cole o resultado em GOOGLE_SERVICE_ACCOUNT_KEY abaixo
# 6. Crie uma pasta raiz no Google Drive e compartilhe com o email da service account
# 7. Copie o ID da pasta raiz (da URL) e cole em GOOGLE_DRIVE_ROOT_FOLDER_ID
#
# ATENÇÃO: Nunca versione o arquivo JSON de credenciais!
# Adicione *.json de chave ao .gitignore e use APENAS esta variável de ambiente.

# JSON serializado da service account (string em uma linha)
GOOGLE_SERVICE_ACCOUNT_KEY=

# ID da pasta raiz no Google Drive para os arquivos do sistema
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# =============================================================================
# EVOLUTION API WEBHOOK SETUP
# =============================================================================
# Para que o WhatsApp funcione corretamente, configure o webhook na Evolution API:
#
# 1. URL do Webhook: {NEXT_PUBLIC_APP_URL}/api/webhooks/evolution
#    Exemplo: https://seu-dominio.com/api/webhooks/evolution
#
# 2. Eventos necessários:
#    - MESSAGES_UPSERT (mensagens recebidas)
#    - MESSAGES_UPDATE (status das mensagens)
#    - CONNECTION_UPDATE (status de conexão)
#    - QRCODE_UPDATED (QR Code atualizado)
#    - CONTACTS_UPSERT (contatos atualizados)
#
# 3. Configuração via API da Evolution:
#    POST {EVOLUTION_API_BASE_URL}/webhook/set/{instance_name}
#    {
#      "url": "{NEXT_PUBLIC_APP_URL}/api/webhooks/evolution",
#      "webhook_by_events": true,
#      "events": [
#        "MESSAGES_UPSERT",
#        "MESSAGES_UPDATE", 
#        "CONNECTION_UPDATE",
#        "QRCODE_UPDATED",
#        "CONTACTS_UPSERT"
#      ]
#    }
#
# 4. Teste o webhook:
#    - Verifique se a URL está acessível publicamente
#    - Confirme que retorna status 200 para requisições POST
#    - Monitore os logs para verificar se os eventos estão chegando

# SMTP Configuration (Email Sending)
# Configure com seus dados de servidor SMTP (Gmail, SendGrid, Mailgun, etc)
# Exemplos de configuração:
#
# Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=seu-email@gmail.com
#   SMTP_PASSWORD=sua-senha-de-app (não a senha normal!)
#
# Outlook/Office365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=sua-api-key
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=AvaliaTec
SMTP_FROM_EMAIL=
